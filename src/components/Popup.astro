---
import SkipForward from "@assets/actions/skip-forward.svg";
import { cn } from "@/utils";

import ShiftKey from "@assets/keys/shift.svg";
import EscKey from "@assets/keys/esc.svg";
import Close from "@assets/actions/close.svg";

type ElementsVisibility = { key: "skip-animation"; visible: boolean }[];
interface Props {
    id: string;
    title: string;
    position?: "top" | "bottom" | "left" | "right";
    visibilities: ElementsVisibility;
    description?: string;
    className?: string;
    containerClassName?: string;
}

const {
    id,
    title,
    position = "left",
    visibilities = [{ key: "skip-animation", visible: true }],
    description,
    className,
    containerClassName,
} = Astro.props;
---

<script>
    class Popup extends HTMLElement {
        static EVENTS = {
            POPUP_OPEN: "popup-open",
            POPUP_CLOSE: "popup-close",
            POPUP_SKIP_FORWARD: "popup-skip-forward",
        };

        #triggerElement: HTMLElement | null = null;
        #closeButton?: HTMLElement | null = null;
        #popupContainer?: HTMLElement | null = null;
        #skipForwardButton?: HTMLElement | null = null;

        #popupOpenEvent = new CustomEvent(Popup.EVENTS.POPUP_OPEN, {
            bubbles: true,
        });

        #popupCloseEvent = new CustomEvent(Popup.EVENTS.POPUP_CLOSE, {
            bubbles: true,
        });

        #popupSkipForwardEvent = new CustomEvent(
            Popup.EVENTS.POPUP_SKIP_FORWARD,
            {
                bubbles: true,
            },
        );

        connectedCallback() {
            this.#init();
            this.#registerVisibilityEvents();
            this.#registerActionsEvents();
            this.#registerKeysEvents();
        }

        #init() {
            const popupId = this.dataset.id;
            if (!popupId) throw new Error("Popup container id is not defined");

            this.#triggerElement = this.querySelector(".popup-trigger");
            this.#closeButton = this.querySelector(".popup-close");
            this.#popupContainer = this.querySelector(
                `#popup-container-${popupId}`,
            );
            this.#skipForwardButton = this.querySelector(
                ".popup-skip-animation",
            );
        }

        #registerVisibilityEvents() {
            this.#triggerElement?.addEventListener("click", () => {
                this.#popupContainer?.classList.remove("tw:hidden");
            });

            this.#closeButton?.addEventListener("click", () => {
                this.#popupContainer?.classList.add("tw:hidden");
            });
            this.#popupContainer?.addEventListener("click", (e) => {
                if (e.target === this.#popupContainer) {
                    this.#popupContainer?.classList.add("tw:hidden");
                }
            });
        }

        #registerActionsEvents() {
            this.#triggerElement?.addEventListener("click", () => {
                this.dispatchEvent(this.#popupOpenEvent);
            });

            this.#closeButton?.addEventListener("click", () => {
                this.dispatchEvent(this.#popupCloseEvent);
            });

            this.#skipForwardButton?.addEventListener("click", () => {
                this.dispatchEvent(this.#popupSkipForwardEvent);
            });
        }

        #registerKeysEvents() {
            document.addEventListener("keydown", (e) => {
                if (this.#popupContainer?.classList.contains("tw:hidden"))
                    return;
                1;
                if (e.key === "Escape") {
                    this.#popupContainer?.classList.add("tw:hidden");
                    this.dispatchEvent(this.#popupCloseEvent);
                } else if (e.key === "Shift") {
                    this.dispatchEvent(this.#popupSkipForwardEvent);
                }
            });
        }
    }
    customElements.define("pop-up", Popup);
</script>

<pop-up data-id={id} id={id} aria-modal="false">
    <div class="popup-trigger">
        <slot name="trigger" />
    </div>
    <div
        id=`popup-container-${id}`
        class="tw:bg-opacity-50 tw:fixed tw:top-0 tw:left-0 tw:z-1000 tw:hidden tw:h-screen tw:backdrop-blur-xl tw:w-screen"
    >
        <div
            class={cn(
                `popup-content tw:max-w-10/12 tw:-translate-y-1/2 tw:top-1/2
        tw:rounded-lg tw:-translate-x-1/2 tw:left-1/2 tw:absolute tw:flex tw:items-start tw:justify-center tw:isolate tw:p-2`,
                className,
            )}
        >
            {
                title !== "" && (
                    <div class="title">
                        <h1>{title}</h1>
                    </div>
                )
            }
            <div class={cn("popup-content-container", containerClassName)}>
                <slot name="content" />
            </div>
            <div
                id="popup-actions"
                class={cn(
                    "tw:p-2 tw:gap-2 tw:w-12 tw:flex tw:flex-col tw:justify-center tw:items-center tw:bg-[var(--popup-actions-background)] tw:rounded-md",
                    !title && "tw:top-4",
                )}
            >
                <button class="popup-close action" aria-label="Close popup">
                    <Close />
                </button>
                {
                    visibilities.find((v) => v.key === "skip-animation")
                        ?.visible && (
                        <button
                            class="popup-skip-animation action"
                            aria-label="Skip animation"
                        >
                            <SkipForward />
                        </button>
                    )
                }
            </div>
            <div id="keys-container">
                <EscKey class="small key" />
                <ShiftKey class="big key" />
            </div>
        </div>
    </div>
</pop-up>

<style>
    @reference "../styles/global.css";

    #keys-container {
        @apply tw:z-10 tw:mt-[5px] tw:flex tw:h-full tw:flex-col tw:justify-center tw:gap-2;
    }

    .title {
        @apply tw:text-center tw:text-2xl tw:font-bold tw:text-ellipsis;
    }

    .popup-content-container {
        @apply tw:relative tw:flex tw:flex-col tw:items-center tw:justify-center tw:overflow-x-scroll tw:rounded-md tw:px-2 tw:sm:w-fit tw:md:min-w-max;
    }

    .key.big {
        @apply tw:h-6 tw:w-8 tw:scale-160;
    }

    .key.small {
        @apply tw:h-6 tw:w-6 tw:scale-160;
    }

    .key {
        @apply tw:ml-4 tw:hidden tw:cursor-default tw:self-start tw:md:block;
    }

    .action {
        @apply tw:w-fit tw:rounded-md tw:bg-[var(--popup-actions)] tw:hover:scale-90;
    }

    svg {
        @apply tw:m-2 tw:h-5 tw:w-5 tw:cursor-pointer;
    }
</style>
