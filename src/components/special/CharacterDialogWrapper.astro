---
import { nanoid } from "nanoid";
import { cn } from "@lib/utils";

type Props = {
    characterName?: string;
    texts?: string[];
    classNames?: {
        characterDialog?: string;
        content?: string;
        characterName?: string;
        texts?: string;
        avatarWrapper?: string;
    };
};

const { characterName, texts, classNames } = Astro.props;
---

<div class={cn("character-dialog", classNames?.characterDialog)}>
    <div class={cn("content", classNames?.content)}>
        <div class={cn("character-name wrapper", classNames?.characterName)}>
            <slot name="character-name">
                <p class="name">{characterName}</p>
            </slot>
        </div>
        <div class={cn("texts", classNames?.texts)}>
            <slot name="texts">
                {
                    texts &&
                        texts.map((text) => (
                            <p class="paragraph" id={nanoid()}>
                                {text}
                            </p>
                        ))
                }
            </slot>
        </div>
    </div>
    <div class={cn("avatar-wrapper", classNames?.avatarWrapper)}>
        <slot name="avatar" />
    </div>
</div>

<style>
    @reference "../../styles/global.css";

    .character-dialog {
        @apply relative flex h-full items-center justify-start overflow-hidden;
    }

    .character-name {
        &::before {
            @apply bg-primary-background absolute right-[calc(100%-6px)] bottom-0 h-full w-full rounded-br-md content-[""];
        }
        @apply text-accent bg-section-secondary shadow-section-secondary relative w-fit justify-self-end rounded-tl-xl rounded-tr-xs py-2 pr-2 pl-3.5 text-5xl;
    }

    .content {
        @apply ml-10 w-1/2;
    }

    .avatar-wrapper {
        @apply absolute right-1/2 bottom-0 md:right-1/4;
    }

    .texts {
        @apply text-foreground bg-section-secondary w-full rounded-tl-md rounded-b-md p-6 text-2xl;

        p.paragraph {
        }
    }
</style>
