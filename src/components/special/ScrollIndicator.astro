---
type Props = {
    class?: string;
};

const { class: className } = Astro.props;
---

<script>
    enum IndicatorState {
        ToIdle,
        Turning,
        Walking,
        Jumping,
    }

    type AnimationInfo = {
        kind: IndicatorState;
        animationName: string;
        framesNumber: number;
        scalingFactor: number;
        secondsDuration: number;
        animationDirection: string;
    };

    const turningAnimation: AnimationInfo = {
        kind: IndicatorState.Turning,
        animationName: "indicator-turning",
        framesNumber: 3,
        scalingFactor: 2,
        secondsDuration: 0.7,
        animationDirection: "forwards",
    };

    const toIdleAnimation: AnimationInfo = {
        ...turningAnimation,
        animationName: "indicator-to-idle",
        kind: IndicatorState.ToIdle,
    };

    const walkingAnimation: AnimationInfo = {
        kind: IndicatorState.Walking,
        animationName: "indicator-walking",
        framesNumber: 4,
        scalingFactor: 2,
        secondsDuration: 0.7,
        animationDirection: "infinite",
    };

    const jumpingAnimation: AnimationInfo = {
        kind: IndicatorState.Jumping,
        animationName: "indicator-jumping",
        framesNumber: 10,
        scalingFactor: 2,
        secondsDuration: 1,
        animationDirection: "forwards",
    };

    class ScrollIndicator extends HTMLElement {
        #currentAnimation?: AnimationInfo;
        #animationDiv?: HTMLDivElement;
        #scrolling: boolean = false;
        #jumping: boolean = false;

        connectedCallback() {
            this.#animationDiv = this.querySelector(
                "#scroll-indicator",
            ) as HTMLDivElement;

            this.#setAnimation(turningAnimation);

            this.addEventListener("mouseenter", () => {
                if (!this.#scrolling) this.#setAnimation(toIdleAnimation);
            });

            this.addEventListener("mouseleave", () => {
                if (!this.#scrolling) this.#setAnimation(turningAnimation);
            });

            document.addEventListener("scroll", () => {
                if (this.#scrolling) return;
                this.#scrolling = true;

                if (this.#currentAnimation?.kind === IndicatorState.ToIdle) {
                    this.#setAnimation(turningAnimation);
                    setTimeout(() => {
                        this.#setAnimation(walkingAnimation);
                    }, turningAnimation.secondsDuration * 1000);
                } else {
                    this.#setAnimation(walkingAnimation);
                }
            });

            document.addEventListener("mouseenter", () => {
                if (this.#jumping) return;
                if (this.#currentAnimation?.kind === IndicatorState.ToIdle) {
                    this.#setAnimation(turningAnimation);
                }
            });

            document.addEventListener("mouseleave", () => {
                this.#jumping = false;
                if (!this.#scrolling) this.#setAnimation(toIdleAnimation);
            });

            document.addEventListener("scrollend", () => {
                this.#scrolling = false;

                this.#setAnimation(toIdleAnimation);
                setTimeout(() => {
                    this.#setAnimation(turningAnimation);
                }, toIdleAnimation.secondsDuration * 1000);
            });

            window.addEventListener("hashchange", () => {
                if (this.#currentAnimation?.kind === IndicatorState.ToIdle) {
                    this.#setAnimation(turningAnimation);
                }

                setTimeout(
                    () => {
                        this.#jumping = true;
                        this.#setAnimation(jumpingAnimation);
                        setTimeout(() => {
                            this.#jumping = false;
                        }, jumpingAnimation.secondsDuration * 1000);
                    },
                    this.#currentAnimation?.kind === IndicatorState.Turning
                        ? turningAnimation.secondsDuration * 1000
                        : 0,
                );
            });
        }

        #setAnimation(animation: AnimationInfo) {
            if (!this.#animationDiv) return;

            this.#currentAnimation = animation;

            this.#animationDiv.style.setProperty(
                "--animation",
                animation.animationName,
            );

            this.#animationDiv.style.setProperty(
                "--animation-duration",
                `${animation.secondsDuration}s`,
            );

            this.#animationDiv.style.setProperty(
                "--animation-direction",
                animation.animationDirection,
            );

            this.#animationDiv.style.setProperty(
                "--frames-number",
                animation.framesNumber.toString(),
            );

            this.#animationDiv.style.animation = "none";
            this.#animationDiv.offsetHeight;
            this.#animationDiv.style.animation = null!;
        }
    }

    customElements.define("scroll-indicator", ScrollIndicator);
</script>

<scroll-indicator class={className}>
    <div id="scroll-indicator"></div>
</scroll-indicator>

<style>
    #scroll-indicator {
        --animation: indicator;
        --start-dimension: 32px;
        --scaling-factor: 2;
        --animation-duration: 1s;
        --frames-number: 3;

        filter: hue-rotate(var(--scroll-indicator-hue-rotate));
        background-image: url("../../assets/sheets/scroll_indicator.png");
        image-rendering: pixelated;
        width: calc(var(--start-dimension) * var(--scaling-factor));
        height: calc(var(--start-dimension) * var(--scaling-factor));
        background-position: 0px 0px;
        background-size: calc(576px * var(--scaling-factor))
            calc(var(--start-dimension) * var(--scaling-factor));
        animation: var(--animation) var(--animation-duration)
            steps(var(--frames-number), jump-none) var(--animation-direction);
    }

    @keyframes indicator-turning {
        from {
            background-position-x: 0px;
        }
        to {
            background-position-x: calc(
                var(--start-dimension) * var(--scaling-factor) * -2
            );
        }
    }

    @keyframes indicator-to-idle {
        from {
            background-position-x: calc(
                var(--start-dimension) * var(--scaling-factor) * -2
            );
        }
        to {
            background-position-x: 0px;
        }
    }

    @keyframes indicator-walking {
        from {
            background-position-x: calc(
                var(--start-dimension) * var(--scaling-factor) * -4
            );
        }
        to {
            background-position-x: calc(
                var(--start-dimension) * var(--scaling-factor) * -7
            );
        }
    }

    @keyframes indicator-jumping {
        from {
            background-position-x: calc(
                var(--start-dimension) * var(--scaling-factor) * -8
            );
        }
        to {
            background-position-x: calc(
                var(--start-dimension) * var(--scaling-factor) * -17
            );
        }
    }

    @media (width <= 768px) {
        #scroll-indicator {
            --scaling-factor: 1.3;
        }
    }
</style>
