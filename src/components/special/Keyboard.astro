---
import "@styles/keyboard.css";

import RandomOrderMeta from "@assets/icons/keyboard_modes/random_order.png";
import RainbowLightMeta from "@assets/icons/keyboard_modes/rainbow_light.png";

type Props = {
  showModesPanel?: boolean;
};

const { showModesPanel = true } = Astro.props;
---

<div class="absolute bottom-0 max-h-fit w-full">
  {
    showModesPanel && (
      <div class="keyboard-modes-panel">
        <h1 class="panel-title md:hidden">Keyboard Light modes</h1>
        <div class="push-buttons">
          <button class="push-button" data-mode="random">
            <img src={RandomOrderMeta.src} />
          </button>
          <button class="push-button active" data-mode="rainbow">
            <img src={RainbowLightMeta.src} />
          </button>
        </div>
      </div>
    )
  }
  <svg viewBox="0 0 395 200" xmlns="http://www.w3.org/2000/svg" class="font-pixelify absolute bottom-0 left-[50%] translate-x-[-50%] transform">
    <rect x="0" y="70" width="395" height="165" rx="18" class="outer-rect"></rect>
    <rect x="10" y="80" width="375" height="145" rx="14" class="inner-rect"></rect>
    <g class="rows-container">
      <!-- Row 1 -->
      <g class="row">
        <rect fill="var(--color-accent)" class="button q" x="20" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol q" x="33" y="103">Q</text>
        <rect fill="var(--color-accent)" class="button w" x="50" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol w" x="63" y="103">W</text>
        <rect fill="var(--color-accent)" class="button e" x="80" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol e" x="93" y="103">E</text>
        <rect fill="var(--color-accent)" class="button r" x="110" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol r" x="123" y="103">R</text>
        <rect fill="var(--color-accent)" class="button t" x="140" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol t" x="153" y="103">T</text>
        <rect fill="var(--color-accent)" class="button y" x="170" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol y" x="183" y="103">Y</text>
        <rect fill="var(--color-accent)" class="button u" x="200" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol u" x="213" y="103">U</text>
        <rect fill="var(--color-accent)" class="button i" x="230" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol i" x="243" y="103">I</text>
        <rect fill="var(--color-accent)" class="button o" x="260" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol o" x="273" y="103">O</text>
        <rect fill="var(--color-accent)" class="button p" x="290" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol p" x="303" y="103">P</text>
        <rect fill="var(--color-accent)" class="button [" x="320" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol [" x="333" y="103">[</text>
        <rect fill="var(--color-accent)" class="button ]" x="350" y="90" width="26" height="26" rx="4"></rect>
        <text class="symbol ]" x="363" y="103">]</text>
      </g>
    </g>

    <!-- Row 2 -->
    <g class="row">
      <rect fill="var(--color-accent)" class="button a" x="35" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol a" x="48" y="135">A</text>
      <rect fill="var(--color-accent)" class="button s" x="65" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol s" x="78" y="135">S</text>
      <rect fill="var(--color-accent)" class="button d" x="95" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol d" x="108" y="135">D</text>
      <rect fill="var(--color-accent)" class="button f" x="125" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol f" x="138" y="135">F</text>
      <rect fill="var(--color-accent)" class="button g" x="155" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol g" x="168" y="135">G</text>
      <rect fill="var(--color-accent)" class="button h" x="185" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol h" x="198" y="135">H</text>
      <rect fill="var(--color-accent)" class="button i" x="215" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol i" x="228" y="135">J</text>
      <rect fill="var(--color-accent)" class="button k" x="245" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol k" x="258" y="135">K</text>
      <rect fill="var(--color-accent)" class="button l" x="275" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol l" x="288" y="135">L</text>
      <rect fill="var(--color-accent)" class="button ;" x="305" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol ;" x="318" y="135">;</text>
      <rect fill="var(--color-accent)" class="button '" x="335" y="122" width="26" height="26" rx="4"></rect>
      <text class="symbol '" x="348" y="135">'</text>
    </g>

    <!-- Row 3 -->
    <g class="row">
      <rect fill="var(--color-accent)" class="button z" x="50" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol z" x="63" y="167">Z</text>
      <rect fill="var(--color-accent)" class="button x" x="80" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol x" x="93" y="167">X</text>
      <rect fill="var(--color-accent)" class="button c" x="110" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol c" x="123" y="167">C</text>
      <rect fill="var(--color-accent)" class="button v" x="140" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol v" x="153" y="167">V</text>
      <rect fill="var(--color-accent)" class="button b" x="170" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol b" x="183" y="167">B</text>
      <rect fill="var(--color-accent)" class="button n" x="200" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol n" x="213" y="167">N</text>
      <rect fill="var(--color-accent)" class="button m" x="230" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol m" x="243" y="167">M</text>
      <rect fill="var(--color-accent)" class="button ," x="260" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol ," x="273" y="167">,</text>
      <rect fill="var(--color-accent)" class="button ." x="290" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol ." x="303" y="167">.</text>
      <rect fill="var(--color-accent)" class="button /" x="320" y="154" width="26" height="26" rx="4"></rect>
      <text class="symbol /" x="333" y="167">/</text>
    </g>
  </svg>
</div>

<script>
  import AudioPlayer from "@lib/audio.ts";
  import PushButtonAudioSrc from "@assets/audio/push_button_press.mp3";
  import { animate, stagger } from "motion";

  enum KeyboardLightMode {
    Rainbow = "rainbow",
    Random = "random",
  }

  AudioPlayer.createAudioPlayer(PushButtonAudioSrc);

  let currentLightMode: KeyboardLightMode | null = null;
  let symbolAnimation: ReturnType<typeof animate> | null = null;
  let buttonAnimations: ReturnType<typeof animate>[] = [];

  const startRainbowMode = () => {
    if (currentLightMode === "rainbow") return;
    stopAll();

    if (currentLightMode !== null) AudioPlayer.playAudio(PushButtonAudioSrc);

    symbolAnimation = animate(
      ".symbol",
      {
        fill: ["rgb(255, 0, 0)", "rgb(0, 255, 0)", "rgb(0, 0, 255)", "rgb(255, 0, 0)"],
      },
      {
        duration: 3,
        repeat: Infinity,
        delay: stagger(0.04),
        ease: "linear",
      },
    );

    currentLightMode = KeyboardLightMode.Rainbow;
  };

  const startRandomMode = () => {
    if (currentLightMode === KeyboardLightMode.Random) return;
    stopAll();

    AudioPlayer.playAudio(PushButtonAudioSrc);

    const texts = document.querySelectorAll<SVGTextElement>(".symbol");
    buttonAnimations = Array.from(texts).map((text) => {
      const hue = Math.random() * 360;
      return animate(
        text,
        {
          fill: [
            `hsl(${hue}, 100%, 50%)`,
            `hsl(${(hue + 72) % 360}, 100%, 50%)`,
            `hsl(${(hue + 144) % 360}, 100%, 50%)`,
            `hsl(${(hue + 216) % 360}, 100%, 50%)`,
            `hsl(${(hue + 288) % 360}, 100%, 50%)`,
            `hsl(${hue}, 100%, 50%)`,
          ],
        },
        {
          duration: 1.5 + Math.random(),
          repeat: Infinity,
          ease: "linear",
        },
      );
    });

    currentLightMode = KeyboardLightMode.Random;
  };

  const stopAll = () => {
    if (symbolAnimation) {
      symbolAnimation.stop();
      symbolAnimation = null;
    }
    buttonAnimations.forEach((a) => a.stop());
    buttonAnimations = [];
  };

  startRainbowMode();

  const animateButton = (btn: SVGRectElement) => {
    const accent = window.getComputedStyle(document.body).getPropertyValue("--color-accent");
    animate(
      btn,
      {
        fill: [accent, "rgb(255, 255, 255)", accent],
      },
      {
        duration: 0.25,
        ease: "easeOut",
      },
    );
  };

  document.querySelectorAll<SVGRectElement>(".button").forEach((btn) => {
    btn.addEventListener("click", () => animateButton(btn));
  });

  document.querySelectorAll<HTMLButtonElement>(".push-button").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".push-button").forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");

      const mode = btn.getAttribute("data-mode");
      switch (mode) {
        case "rainbow":
          startRainbowMode();
          break;
        case "random":
          startRandomMode();
          break;
      }
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.repeat || e.key.length > 1) return;
    const btn = document.querySelector(`.button.${CSS.escape(e.key)}`);
    if (btn) animateButton(btn as SVGRectElement);
  });
</script>
