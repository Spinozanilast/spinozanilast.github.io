---
import { cn } from "@lib/utils";

import SquareBracket from "@assets/square_bracket.svg";

interface Props {
  title: string;
  link: string;
  description?: string;
  separateTab?: boolean;
  className?: string;
}

const { title, description, link, separateTab = true, className } = Astro.props;
---

<a class="reference-link text-foreground-accent-red font-departuremono text-dm-sm w-full min-w-1/3 font-medium focus:scale-[1.1]" href={link} target={separateTab ? "_blank" : ""}>
  <div class="reference group fill-foreground-accent-red flex h-25 max-h-60 max-w-full min-w-max flex-row justify-between hover:scale-[1.1] active:scale-[1.1]">
    <SquareBracket class="bracket-icon" />
    <div title={description} class={cn("reference-content text-foreground flex flex-row items-center justify-center gap-[0.5em] text-3xl", className)}>
      <slot />

      {title}
    </div>
    <SquareBracket class="bracket-icon rotate-180" />
  </div>
</a>

<style>
  @reference "../global.css";

  .reference-content {
    @apply text-foreground flex flex-row items-center justify-center gap-[0.5em] text-3xl;

    svg {
      @apply max-w-16 min-w-2;

      @media (width <= 700px) {
        @apply w-12;
      }
    }

    @media (width <= 700px) {
      @apply flex-col text-xl;
    }
  }

  @media (width <= 500px) {
    .reference {
      @apply h-full w-full justify-center;

      svg {
        @apply w-32;
      }
    }

    .bracket-icon {
      @apply hidden;
    }
  }
</style>
