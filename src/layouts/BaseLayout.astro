---
import DarkLightSwitcher from "@components/special/DarkLightSwitcher.astro";
import PersonalityPopup from "@popups/PersonalityPopup.astro";
import { SEO } from "astro-seo";

import "@/styles/global.css";

type Props = {
    title?: string;
    renderUtilitiesPanel?: boolean;
};

const { title, renderUtilitiesPanel = true } = Astro.props;
const defaultTitle = "Spinozanilast's Diary";
const fullTitle = title ? `${title} — ${defaultTitle}` : defaultTitle;
const description = "Spinozanilast's Diary or better to say, that there would be some info about Vadim Budchanin. Yeah, that's me, and I'm writing this diary/blog/devlog and a lot of other stuff.";
---

<!doctype html>
<html lang="en">
    <head>
        <SEO
            title={title}
            titleTemplate={`%s — ${defaultTitle}`}
            titleDefault={defaultTitle}
            description={description}
            openGraph={{
                basic: {
                    title: fullTitle,
                    type: "website",
                    image: "/favicon.svg",
                    url: Astro.url,
                },
                optional: {
                    description,
                    siteName: "Spinozanilast's Diary",
                    locale: "en_US",
                },
                image: {
                    alt: "Spinozanilast logo",
                },
            }}
            twitter={{
                card: "summary",
                title: fullTitle,
                description,
                image: "/favicon.svg",
                imageAlt: "Spinozanilast logo",
            }}
        />
        <meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0,  minimum-scale=1.0" /><meta
            name="keywords"
            content="Spinozanilast, Vadim Budchanin, diary, Astro SEO"
        /><link rel="icon" type="image/svg+xml" href="/favicon.svg" /><link rel="preload" href="/fonts/DepartureMono.woff2" type="font/woff2" as="font" crossorigin="anonymous" /><link
            rel="preload"
            href="/fonts/Extrude.woff2"
            type="font/woff2"
            as="font"
            crossorigin="anonymous"
        /><link rel="preload" href="/fonts/PixelifySans.woff2" type="font/woff2" as="font" crossorigin="anonymous" /><link
            rel="preload"
            href="/fonts/Retrogression.woff2"
            type="font/woff2"
            as="font"
            crossorigin="anonymous"
        /><meta name="generator" content={Astro.generator} />
    </head>
</html>
<body>
    {
        renderUtilitiesPanel && (
            <div class="bg-section-background rounded-xsl absolute top-1.5 right-1.5 z-10 flex flex-row gap-2 p-2">
                <DarkLightSwitcher />
                <PersonalityPopup />
            </div>
        )
    }
    <slot />
</body>

<script is:inline>
    const theme = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    document.documentElement.setAttribute("data-theme", theme);
</script>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        min-height: 100%;
    }

    body {
        @apply font-["PixelifySans"];
    }
</style>
