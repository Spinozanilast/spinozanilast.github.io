---
import { Icon } from "astro-icon/components";

import BaseLayout from "./BaseLayout.astro";
import ScrollIndicator from "@/components/special/ScrollIndicator.astro";
import DarkLightSwitcher from "@components/special/DarkLightSwitcher.astro";
import PersonalityPopup from "@components/popups/PersonalityPopup.astro";

import "@styles/layouts/home.css";

const currentPath = Astro.url.pathname;

const pageIcons: Record<string, string> = {
    "/home": "home",
    "/about": "info",
    "/projects": "projects",
    "/notes": "notes",
};

const currentIcon = pageIcons[currentPath] ?? "link";
---

<script>
    let lastScrollY = 0;
    const navWrapper = document.getElementById("nav-wrapper") as HTMLElement;

    navWrapper.dataset.scrollDir = "up";

    function onScroll() {
        const currentScrollY = window.scrollY;
        if (currentScrollY < lastScrollY) {
            navWrapper.dataset.scrollDir = "up";
        } else if (currentScrollY > lastScrollY) {
            navWrapper.dataset.scrollDir = "down";
        }
        lastScrollY = currentScrollY;
    }

    window.addEventListener("scroll", onScroll, { passive: true });

    const hamburger = document.getElementById("hamburger") as HTMLButtonElement;
    const navLinks = navWrapper?.querySelectorAll("a");
    const navIcon = navWrapper?.querySelector("#nav-icon") as HTMLDivElement;
    const nav = navWrapper?.querySelector("nav") as HTMLDivElement;

    hamburger?.addEventListener("click", () => {
        const isOpen = navWrapper.dataset.menuOpen === "true";
        navWrapper.dataset.menuOpen = isOpen ? "false" : "true";
        document.documentElement.classList.toggle("overflow-hidden", !isOpen);
    });

    navLinks?.forEach((link) => {
        link.addEventListener("click", () => {
            navWrapper.dataset.menuOpen = "false";
        });
    });

    document.addEventListener("click", (e) => {
        if (
            navWrapper.dataset.menuOpen === "true" &&
            !navWrapper.contains(e.target as Node)
        ) {
            navWrapper.dataset.menuOpen = "false";
        }
    });

    const resizeObserver = new ResizeObserver(() => {
        if (window.innerWidth >= 1000) {
            document.documentElement.classList.remove("overflow-hidden");
        }
    });

    resizeObserver.observe(document.documentElement);
</script>

<BaseLayout renderUtilitiesPanel={false}>
    <button id="hamburger" class="mobile-only" aria-label="Toggle menu"
        >☰</button
    >
    <div id="nav-wrapper">
        <div id="nav-icon">
            <Icon name={currentIcon} />
        </div>
        <nav>
            <a class={currentPath === "/home" ? "active" : ""} href="/home"
                >Home</a
            >
            <a
                class={currentPath === "/projects" ? "active" : ""}
                href="/projects">Projects</a
            >
            <a href="/" class="special"><div id="snake-logo"></div></a>
            <a class={currentPath === "/notes" ? "active" : ""} href="/notes"
                >Notes</a
            >
            <a class={currentPath === "/about" ? "active" : ""} href="/about"
                >About</a
            >
        </nav>
    </div>
    <a href="/" class="mobile-only"><div id="snake-logo"></div></a>
    <div class="util-panel">
        <ScrollIndicator class="z-10" />
        <div class="flex flex-col gap-2">
            <DarkLightSwitcher />
            <PersonalityPopup />
        </div>
    </div>
    <main>
        <slot />
    </main>
</BaseLayout>
