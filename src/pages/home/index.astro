---
import { Image } from "astro:assets";

import HomeLayout from "@layouts/HomeLayout.astro";

import SectionWithTitle from "@features/home/SectionWithTitle.astro";
import CharacterDialogWrapper from "@features/home/CharacterDialogWrapper.astro";
import RemCylinder from "@features/home/RemCylinder.astro";
import Keyboard from "@features/home/Keyboard.astro";
import GithubStats from "@features/home/GithubStats.astro";

import RightHand from "@features/home/RightHand";
import SpotifyNowPlaying from "@features/home/SpotifyNowPlaying";

import FoldedPaperCorner from "@assets/folded_paper_corner.png";
import RotateBehind from "@assets/icons/actions/rotate_behind.svg";
import LeftHand from "@assets/arts/left_hand_of_two.svg";
import Eurasia from "@assets/eurasia.svg";
---

<HomeLayout title="Home">
  <div
    id="killer-dialog-wrapper"
    class="relative hidden h-dvh items-center justify-start overflow-hidden"
  >
    <CharacterDialogWrapper id="killer-dialog">
      <div slot="character-name">
        <h1 id="killer-character-name">?</h1>
      </div>
      <div slot="texts">
        <h1 id="killer-fraze" class="mr-5"></h1>
      </div>
      <div slot="avatar" id="killer-avatar"></div>
    </CharacterDialogWrapper>
  </div>
  <div id="sections-wrapper" class="hidden">
    <section
      id="paper"
      class="mt-30 flex h-fit max-h-fit min-h-dvh flex-row flex-wrap items-center justify-center gap-10 p-6"
    >
      <div
        id="about-self-paper"
        class="front-side bg-paper-background font-retrogression border-paper-border relative m-5 aspect-[1/0.7] max-h-[70%] w-full border-2 p-4 md:aspect-[1/1.35] md:w-1/2 2xl:aspect-[1/1.1] 2xl:w-1/4"
      >
        <button
          id="rotate-paper"
          class="fill-accent absolute -top-20 right-1 md:-top-10 md:-right-10"
          aria-label="rotate paper"
        >
          <RotateBehind class="h-15 w-15 cursor-pointer hover:scale-110" />
        </button>
        <div id="front-side">
          <h1 class="text-5xl">
            Hey there, that's <b>Spinozanilast</b> /
            <i>Vadim Budchanin</i>
          </h1>
          <br />
          <h2 class="text-3xl">I'm software engineer</h2>
          <h2 class="text-3xl">who likes making next things:</h2>
          <ul>
            <a href="#projects">
              <li
                class="decoration-accent before:text-accent before:font-departuremono relative flex w-fit flex-row items-center text-3xl decoration-3 underline-offset-1 before:mr-2 before:content-['✧'] hover:underline"
              >
                writing code
              </li>
            </a>
            <a href="#notes">
              <li
                class="decoration-accent before:text-accent before:font-departuremono relative flex w-fit flex-row items-center text-3xl decoration-3 underline-offset-1 before:mr-2 before:content-['✧'] hover:underline"
              >
                writing stuff
              </li>
            </a>
            <a href="#art">
              <li
                class="decoration-accent before:text-accent before:font-departuremono relative flex w-fit flex-row items-center text-3xl decoration-3 underline-offset-1 before:mr-2 before:content-['✧'] hover:underline"
              >
                making some art
              </li>
            </a>
            <a href="#future">
              <li
                class="decoration-accent before:text-accent before:font-departuremono relative flex w-fit flex-row items-center text-3xl decoration-3 underline-offset-1 before:mr-2 before:content-['✧'] hover:underline"
              >
                and a lot more in future
              </li>
            </a>
          </ul>
          <br />
          <h2 class="text-3xl">Nice to meet you!</h2>
          <Image
            class="folded-paper-corner absolute -right-1 -bottom-1 h-16 w-16"
            src={FoldedPaperCorner}
            alt="folded paper corner"
          />
          <div
            id="snake-mark"
            class="font-pixelify absolute bottom-1 left-1 text-4xl"
            style="text-shadow:0px 8px 0px var(--color-foreground)"
          >
            S
          </div>
        </div>
        <div id="back-side" class="hidden">
          <h1 class="text-5xl">For those looking for me:</h1>
          <br />
          <h2 class="text-3xl">Do you really think I'm that easy to reach?</h2>
          <br />
          <h2 class="text-3xl">
            Not as easy as it seems, so look for information <a
              class="decoration-accent underline decoration-2"
              href=""
            >
              here
            </a>
          </h2>
        </div>
      </div>
      <div
        id="skills-cylinder"
        class="font-pixelify relative flex h-full w-full items-center justify-center md:w-[50%]"
      >
        <button
          id="rotate-cylinder"
          class="bg-section-background text-dm-sm text-accent absolute -top-3 -right-3 z-10 h-fit w-fit cursor-pointer rounded-md border-0 p-2"
          aria-label="rotate cylinder"
        >
          Tap me
        </button>
        <RemCylinder id="cylinder" class="max-h-[85%]" />
      </div>
    </section>
    <div id="horizontal-snap-container" class="relative h-[200vh]">
      <div class="sticky top-0 h-screen overflow-hidden">
        <div id="horizontal-snap-content" class="flex snap-y snap-mandatory">
          <SectionWithTitle id="projects" title="/ Projects">
            <div
              class="top-projects relative grid h-full w-full grid-cols-1 grid-rows-3 gap-4 md:grid-cols-3 md:grid-rows-1"
            >
              <div
                class="project bg-section-background relative w-full rounded-lg p-4 shadow-lg"
              >
                <h1
                  class="idx font-extrude text-dm-7xl text-accent absolute -top-4 -left-2 italic"
                >
                  1
                </h1>
              </div>
              <div
                class="project bg-section-background relative w-full rounded-lg p-4 shadow-lg"
              >
                <h1
                  class="idx font-extrude text-dm-7xl text-accent absolute -top-4 -left-2 italic"
                >
                  2
                </h1>
              </div>
              <div
                class="project bg-section-background relative w-full rounded-lg p-4 shadow-lg"
              >
                <h1
                  class="idx font-extrude text-dm-7xl text-accent absolute -top-4 -left-2 italic"
                >
                  3
                </h1>
              </div>
            </div>
            <Keyboard slot="after-content" />
          </SectionWithTitle>
          <SectionWithTitle id="art" title="/ Art">
            <LeftHand
              class="fill-accent absolute top-[50%] left-0 w-[47%] translate-y-[-50%]"
              slot="after-content"
            />
            <RightHand
              className="text-accent absolute top-[50%] right-0 w-[50%] translate-y-[-50%] text-[0.5vw]"
              slot="after-content"
            />
          </SectionWithTitle>
        </div>
      </div>
    </div>
    <SectionWithTitle id="about" title="/ About">
      <div
        class="bento flex h-full w-full grid-cols-5 grid-rows-4 flex-col place-items-center gap-3 p-2 md:grid"
      >
        <div class="col-span-2 flex w-full items-center justify-center">
          <SpotifyNowPlaying client:load />
        </div>
        <div
          class="relative col-span-3 row-span-2 flex h-full w-full items-center justify-center"
        >
          <div
            class="bg-section-background text-accent font-departuremono text-dm-sm md:text-dm-base absolute top-0 left-0 z-2 flex w-full items-center gap-4 rounded-md p-4 text-balance"
          >
            yeah, i'm living in Belarus
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 32 32"
            >
              <path
                d="M1,8v13H31V8c0-2.209-1.791-4-4-4H5c-2.209,0-4,1.791-4,4Z"
                fill="#be2d27"
              >
              </path>
              <path
                d="M5,20H27c2.208,0,4,1.792,4,4v4H1v-4c0-2.208,1.792-4,4-4Z"
                transform="rotate(180 16 24)"
                fill="#367b37"
              >
              </path>
              <path fill="#fff" d="M4 13L5 16 4 19 3 16 4 13z"></path>
              <path fill="#fff" d="M2.5 8L3.5 11 2.5 14 1.5 11 2.5 8z"></path>
              <path fill="#fff" d="M5.5 8L6.5 11 5.5 14 4.5 11 5.5 8z"></path>
              <path fill="#fff" d="M2.5 18L3.5 21 2.5 24 1.5 21 2.5 18z"></path>
              <path fill="#fff" d="M5.5 18L6.5 21 5.5 24 4.5 21 5.5 18z"></path>
              <path fill="#fff" d="M1 13L1 19 2 16 1 13z"></path>
              <path fill="#fff" d="M7 13L6 16 7 19 7 13z"></path>
              <path
                d="M5,6l-.645-1.935c-.27,.044-.53,.113-.779,.208l-.576,1.727,1,3,1-3Z"
                fill="#fff"
              >
              </path>
              <path
                d="M1.853,5.558c-.526,.677-.853,1.518-.853,2.442v1l1-3-.147-.442Z"
                fill="#fff"
              >
              </path>
              <path fill="#fff" d="M6.667 4L6 6 7 9 7 4 6.667 4z"></path>
              <path
                d="M5,26l-.645,1.935c-.27-.044-.53-.113-.779-.208l-.576-1.727,1-3,1,3Z"
                fill="#fff"
              >
              </path>
              <path
                d="M1.853,26.442c-.526-.677-.853-1.518-.853-2.442v-1l1,3-.147,.442Z"
                fill="#fff"
              >
              </path>
              <path fill="#fff" d="M6.667 28L6 26 7 23 7 28 6.667 28z"></path>
              <path
                d="M27,4H5c-2.209,0-4,1.791-4,4V24c0,2.209,1.791,4,4,4H27c2.209,0,4-1.791,4-4V8c0-2.209-1.791-4-4-4Zm3,20c0,1.654-1.346,3-3,3H5c-1.654,0-3-1.346-3-3V8c0-1.654,1.346-3,3-3H27c1.654,0,3,1.346,3,3V24Z"
                opacity=".15"
              >
              </path>
              <path
                d="M27,5H5c-1.657,0-3,1.343-3,3v1c0-1.657,1.343-3,3-3H27c1.657,0,3,1.343,3,3v-1c0-1.657-1.343-3-3-3Z"
                fill="#fff"
                opacity=".2"
              >
              </path>
            </svg>
            (прывітанне)
          </div>
          <div class="map-zoom-wrapper">
            <Eurasia class="map-svg" />
          </div>
        </div>
        <div class="col-span-2 w-full">
          <GithubStats />
        </div>
      </div>
    </SectionWithTitle>
  </div>
</HomeLayout>

<script>
  import DialogController, {
    DIALOG_LOCAL_STORAGE_KEY,
    type DialogState,
  } from "@lib/controllers/dialog";
  import { changeElementHideState } from "@/lib/utils";
  import Typewriter from "@lib/typewriter";
  import AudioPlayer from "@lib/audio";

  import CylinderSpinAudioSrc from "@assets/audio/cylinder_spin.mp3";

  import { animate, scroll } from "motion";

  /*
      Section Scroll Animation
  */

  const sections = document.querySelectorAll("#horizontal-snap-container section");

  scroll(
    animate("#horizontal-snap-container section", {
      transform: ["translateX(0)", `translateX(-${sections.length - 1}00vw)`],
    }),
    {
      target: document.querySelector("#horizontal-snap-container") as HTMLElement,
    },
  );

  /*
      Cylinder Hover Rotation
    */

  const setupCylinderHover = (
    linkSelector: string,
    targetSelector: string,
    duration = 3,
  ) => {
    const link = document.querySelector(linkSelector);
    if (!link) return;

    const targets = document.querySelectorAll<SVGGElement>(
      `#skills-cylinder ${targetSelector}`,
    );
    if (targets.length === 0) return;

    const animations = Array.from(targets).map((target) =>
      animate(
        target,
        // @ts-ignore
        { rotate: [0, 360] },
        { duration, repeat: Infinity, easing: "linear" },
      ),
    );
    animations.forEach((a) => a.pause());

    link.addEventListener("mouseenter", () => animations.forEach((a) => a.play()));
    link.addEventListener("mouseleave", () => animations.forEach((a) => a.pause()));
  };

  setupCylinderHover('a[href="#projects"]', "g#code");
  setupCylinderHover('a[href="#notes"]', "g#stuff");
  setupCylinderHover('a[href="#art"]', "g#art");
  setupCylinderHover('a[href="#future"]', "g.circular-text.future", 5);

  /*
      Cylinder Spin Button
    */

  const cylinder = document.querySelector<SVGElement>("#cylinder");
  const rotateCylinderBtn = document.getElementById("rotate-cylinder");

  AudioPlayer.createAudioPlayer(CylinderSpinAudioSrc);

  let isSpinning = false;

  rotateCylinderBtn?.addEventListener("click", () => {
    if (isSpinning || !cylinder) return;
    isSpinning = true;

    AudioPlayer.playAudio(CylinderSpinAudioSrc);

    animate(
      cylinder,
      // @ts-ignore
      { rotate: [0, 720] },
      { duration: 3, easing: [0.0, 0.0, 0.58, 1.0] },
    ).finished.then(() => {
      isSpinning = false;
    });
  });

  /*
      Page Event Loop
  */

  if ((localStorage.getItem(DIALOG_LOCAL_STORAGE_KEY) as DialogState) !== "ended") {
    changeElementHideState("killer-dialog-wrapper", false);

    const killerFrazes = [
      `Wait, who are you? Could it be that at the moment I realized I wasn't a trembling creature, but had a right, the owner wasn't home and a simple passerby showed up?
    <br><br>Anyway, it doesn't matter...`,

      `I won't stay here long, all I found of value was this piece of paper with a note about a local inhabitant.`,

      `I hope this helps you, although I don't know why you came here. Just in case, I wasn't here and you didn't see me.`,
    ];

    const killerAvatar = document.getElementById("killer-avatar");

    const frazesActions: (() => void)[] = [
      () => {
        killerAvatar?.classList.toggle("hidden-face", true);
        killerAvatar?.classList.toggle("show-face", false);
      },
      () => {
        killerAvatar?.classList.toggle("hidden-face", false);
        killerAvatar?.classList.toggle("show-face", true);

        const characterName = document.getElementById(
          "killer-character-name",
        ) as HTMLHeadingElement as HTMLHeadingElement;
        if (characterName) {
          characterName.innerText = "Killer";
        }
      },
    ];

    const typewriter = new Typewriter(true, 80);
    DialogController.registerTypewriter(typewriter);

    const frazesHeading = document.getElementById("killer-fraze") as HTMLHeadingElement;

    if (frazesHeading) {
      DialogController.startDialog({
        texts: killerFrazes,
        targetElement: frazesHeading,
        onComplete: () => {
          killerAvatar?.classList.toggle("hide-avatar", true);

          setTimeout(() => {
            const dialogWrapper = document.getElementById("killer-dialog-wrapper");
            if (dialogWrapper) {
              dialogWrapper.parentNode?.removeChild(dialogWrapper);
            }

            changeElementHideState("sections-wrapper", false);
          }, 2500);
        },
        onFrazesActions: frazesActions,
        hideMsDelay: 2.5,
      });
    }
  } else {
    const dialogWrapper = document.getElementById("killer-dialog-wrapper");
    if (dialogWrapper) {
      dialogWrapper.parentNode?.removeChild(dialogWrapper);
    }

    changeElementHideState("sections-wrapper", false);
  }

  document.getElementById("rotate-paper")?.addEventListener("click", () => {
    const paper = document.getElementById("about-self-paper");
    if (!paper) return;

    const frontSide = paper.querySelector("#front-side");
    const backSide = paper.querySelector("#back-side");

    if (frontSide && backSide) {
      frontSide.classList.toggle("hidden");
      backSide.classList.toggle("hidden");

      paper.classList.toggle("back-side");
      paper.classList.toggle("front-side");
    }
  });
</script>

<style>
  @reference "../../global.css";

  #killer-avatar {
    background-image: url("../../assets/sheets/killer_character.png");
    image-rendering: pixelated;
    text-align: justify;
    width: 140px;
    height: 128px;
    transform: translateY(-42%);
    background-position-x: 0px;
    background-size: 700px 128px;

    &.hidden-face {
      animation: secret-appear 2.5s ease-in-out forwards;
    }

    &.show-face {
      animation: face-appear 1.5s steps(3, jump-end) infinite;
    }

    &.hide-avatar {
      animation: hide-killer 2.5s ease-in-out forwards;
    }
  }

  @keyframes secret-appear {
    from {
      scale: 5;
      opacity: 0;
      filter: hue-rotate(45deg);
    }
    to {
      opacity: 1;
      scale: 6;
    }
  }

  @keyframes hide-killer {
    from {
      background-position-x: -420px;
      scale: 6;
    }
    to {
      opacity: 0;
      scale: 5;
      filter: hue-rotate(45deg);
      background-position-x: -420px;
    }
  }

  @keyframes face-appear {
    from {
      scale: 6;
      background-position-x: -420px;
    }
    to {
      background-position-x: 0px;
      scale: 6;
    }
  }

  #about-self-paper.front-side::after {
    @apply bg-primary-background absolute -right-1 -bottom-1 h-14 w-14 content-[""];
    clip-path: polygon(0% 100%, 100% 100%, 100% 0%);
  }

  #about-self-paper.back-side::before {
    @apply bg-primary-background absolute -bottom-1 -left-1 h-14 w-14 content-[""];
    clip-path: polygon(0% 0%, 0% 100%, 100% 100%);
  }

  .folded-paper-corner {
    image-rendering: pixelated;
  }

  [data-theme="dark"] .folded-paper-corner {
    filter: brightness(0.5);
  }

  .map-zoom-wrapper {
    @apply flex h-full w-full items-center justify-center overflow-hidden;
  }

  .map-svg {
    @apply h-full w-full origin-[20%_60%] rounded-md transition-transform duration-1000 ease-in-out md:origin-[35%_60%];
    color: var(--color-accent);
    filter: hue-rotate(var(--scroll-indicator-hue-rotate));
  }

  .map-zoom-wrapper:hover .map-svg {
    transform: scale(5);
  }

  #rotate-cylinder {
    transition: filter 0.15s ease;
  }

  #rotate-cylinder:hover {
    filter: brightness(1.2);
  }

  #rotate-cylinder:active {
    filter: brightness(0.8);
  }

  .bento {
    > div {
      @apply bg-section-background h-full w-full rounded-md p-4;
    }
  }
</style>
