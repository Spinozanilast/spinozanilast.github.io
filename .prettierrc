{
  "htmlWhitespaceSensitivity": "ignore",
  "overrides": [
    {
      "files": "*.astro",
      "options": {
        "parser": "astro"
      }
    }
  ],
  "plugins": [
    "prettier-plugin-astro",
    "prettier-plugin-tailwindcss",
    "prettier-plugin-sort-json"
  ],
  "printWidth": 88,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false
}
